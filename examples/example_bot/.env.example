# example_bot environment configuration.
# Copy to `.env` (in this same folder) and fill in your real values.
# `.env` is gitignored; never commit one with real secrets.

# ====== Required for the auto-redeem step ======

# EOA private key. This is the wallet that SIGNS transactions; the
# Polymarket Safe wallet that holds your positions is discovered
# automatically from this EOA. Hex string, 0x-prefixed, 64 chars.
POLYMARKET_PRIVATE_KEY=

# Optional: explicit Polygon RPC URL (e.g. an Alchemy / Infura /
# QuickNode endpoint with your API key). Leave blank to fall back to
# the built-in list of public Polygon endpoints with automatic retry.
POLYGON_RPC_URL=


# ====== Reserved for future versions of example_bot ======
# Not used in v0.1 (observation-only). Will be required when order
# placement lands in v0.4.

# CLOB authenticated REST endpoints (placing/canceling orders, user WS
# channel). Generated via the Polymarket UI's API key page or via
# `py-clob-client-v2.create_or_derive_api_key`.
# CLOB_API_KEY=
# CLOB_API_SECRET=
# CLOB_API_PASSPHRASE=

# Optional: explicit Safe (FUNDER) address. Omit and the library
# discovers it from the EOA. Useful when you want to override or when
# running a Safe that is NOT the canonical Polymarket-derived one.
# POLYMARKET_FUNDER_ADDRESS=

# Optional: SOCKS5 proxy for outbound HTTP/WS (residential routing,
# region pinning, etc). Format: socks5://user:pass@host:port
# PROXY_URL=
